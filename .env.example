# Environment Variables for AHM Web (Production Template)

# Secret Key for Flask Session Security (generate a secure random key)
FLASK_SECRET_KEY="your-secure-random-secret-key-here"

# Email Configuration for OTP Verification and Activity Logs
MAIL_USERNAME="your-email@gmail.com"
MAIL_PASSWORD="your-app-specific-password"
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USE_TLS=false

# Optional Configurations
DATABASE_PATH="instance/users.db"
PORT=5000
FLASK_DEBUG=false
DISABLE_2FA=false

# Security Settings
ADMIN_SECURITY_KEY="your-admin-registration-key"
DEFAULT_ADMIN_PASSWORD="your-default-admin-password"

# Razorpay Configuration (Payment Gateway)
RAZORPAY_KEY_ID="rzp_test_your_key_here"
RAZORPAY_KEY_SECRET="your_secret_here"

# Google Drive API Configuration (For File Uploads and Storage)
GOOGLE_DRIVE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_DRIVE_CLIENT_SECRET="your-client-secret"
GOOGLE_DRIVE_REFRESH_TOKEN="your-refresh-token"
GOOGLE_DRIVE_FOLDER_ID="your-main-folder-id"

# Optional Organizer Subfolders
GOOGLE_DRIVE_FOLDER_GALLERY=""
GOOGLE_DRIVE_FOLDER_STUDENTS=""
GOOGLE_DRIVE_FOLDER_TEACHERS=""
GOOGLE_DRIVE_FOLDER_CV=""
GOOGLE_DRIVE_FOLDER_DOCUMENTS=""
GOOGLE_DRIVE_FOLDER_PROOFS=""
GOOGLE_DRIVE_FOLDER_AVATARS=""
GOOGLE_DRIVE_FOLDER_QUESTION_PAPERS=""
